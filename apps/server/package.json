{
  "name": "@xmux/server",
  "version": "0.0.0",
  "description": "Local xmux server for coordinating coding-agent harnesses and chat adapters.",
  "keywords": [
    "coding-agent",
    "control-plane",
    "xmux"
  ],
  "homepage": "https://github.com/ishaksebsib/xmux#readme",
  "bugs": {
    "url": "https://github.com/ishaksebsib/xmux/issues"
  },
  "license": "MIT",
  "author": "Ishak Sebsib",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishaksebsib/xmux.git",
    "directory": "apps/server"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./platform/node": {
      "import": {
        "types": "./dist/platform/node.d.mts",
        "default": "./dist/platform/node.mjs"
      }
    },
    "./status": {
      "import": {
        "types": "./dist/status.d.mts",
        "default": "./dist/status.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "RUN_INTEGRATION=true vitest run tests/integration --no-file-parallelism --testTimeout 30000",
    "typecheck": "tsgo --noEmit",
    "lint:effect": "effect-language-service diagnostics --project tsconfig.json"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@effect/sql-libsql": "catalog:",
    "@xmux/chat-adapter-discord": "workspace:*",
    "@xmux/chat-adapter-slack": "workspace:*",
    "@xmux/chat-adapter-telegram": "workspace:*",
    "@xmux/chat-core": "workspace:*",
    "@xmux/harness-core": "workspace:*",
    "@xmux/harness-opencode": "workspace:*",
    "@xmux/harness-pi": "workspace:*",
    "@xmux/orchestrator": "workspace:*",
    "effect": "catalog:",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@xmux/ts-config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
