{
  "name": "@xmux/cli",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/ishaksebsib/xmux",
  "license": "MIT",
  "author": "Ishak Sebsib",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishaksebsib/xmux.git"
  },
  "bin": {
    "xmux": "./dist/bin/xmux.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "pnpm -s build && RUN_INTEGRATION=true vitest run tests/integration --no-file-parallelism --testTimeout 30000",
    "typecheck": "tsgo --noEmit",
    "lint:effect": "effect-language-service diagnostics --project tsconfig.json"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@xmux/server": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@xmux/ts-config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
