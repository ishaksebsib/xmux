{
  "name": "@xmux/store-sqlite",
  "version": "0.1.0",
  "description": "Lifecycle-managed SQLite store for @xmux/orchestrator.",
  "homepage": "https://github.com/ishaksebsib/xmux",
  "license": "MIT",
  "author": "Ishak Sebsib",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishaksebsib/xmux.git",
    "directory": "packages/store-sqlite"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./migrations": {
      "import": {
        "types": "./dist/migrations.d.mts",
        "default": "./dist/migrations.mjs"
      },
      "require": {
        "types": "./dist/migrations.d.cts",
        "default": "./dist/migrations.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@libsql/client": "catalog:",
    "@xmux/orchestrator": "workspace:*",
    "better-result": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@xmux/ts-config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
